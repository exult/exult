	static/intro_flx.h

all: static/usecode static/fonts.vga static/gumps.vga static/mainshp.flx static/palettes.flx static/paperdol.vga static/shapes.vga static/sprites.vga static/intro.flx

install: all
	mkdir -p $(demodir)
	mkdir -p $(demodir)/static
	cp static/usecode $(demodir)/static/usecode
	cp static/fonts.vga $(demodir)/static/fonts.vga
	cp static/gumps.vga $(demodir)/static/gumps.vga
	cp static/mainshp.flx $(demodir)/static/mainshp.flx
	cp static/palettes.flx $(demodir)/static/palettes.flx
	cp static/paperdol.vga $(demodir)/static/paperdol.vga
	cp static/shapes.vga $(demodir)/static/shapes.vga
	cp static/sprites.vga $(demodir)/static/sprites.vga
	cp static/avatar_data.txt $(demodir)/static/avatar_data.txt
	cp static/blends.dat $(demodir)/static/blends.dat
	cp static/bodies.txt $(demodir)/static/bodies.txt
	cp static/combos.flx $(demodir)/static/combos.flx
	cp static/container.dat $(demodir)/static/container.dat
	cp static/equip.dat $(demodir)/static/equip.dat
	cp static/exultgame.xml $(demodir)/static/exultgame.xml
	cp static/gump_info.txt $(demodir)/static/gump_info.txt
	cp static/initgame.dat $(demodir)/static/initgame.dat
	cp static/intro_info.txt $(demodir)/static/intro_info.txt
	cp static/monsters.dat $(demodir)/static/monsters.dat
	cp static/paperdol_info.txt $(demodir)/static/paperdol_info.txt
	cp static/ready.dat $(demodir)/static/ready.dat
	cp static/shape_files.txt $(demodir)/static/shape_files.txt
	cp static/shape_info.txt $(demodir)/static/shape_info.txt
	cp static/textmsg.txt $(demodir)/static/textmsg.txt
	cp static/tfa.dat $(demodir)/static/tfa.dat
	cp static/u7chunks $(demodir)/static/u7chunks
	cp static/u7ifix42 $(demodir)/static/u7ifix42
	cp static/u7ifix4d $(demodir)/static/u7ifix4d
	cp static/u7ifix4e $(demodir)/static/u7ifix4e
	cp static/u7map $(demodir)/static/u7map
	cp static/weapons.dat $(demodir)/static/weapons.dat
	cp static/wgtvol.dat $(demodir)/static/wgtvol.dat
	cp static/wihh.dat $(demodir)/static/wihh.dat
	cp src/graphics/pointers/pointers.shp $(demodir)/static/pointers.shp
	cp ReadMe.txt $(demodir)/ReadMe.txt
	cp ./../../COPYING $(demodir)/License.txt

uninstall:
	rm -rf $(demodir)/static

$(EXPACK):
	+(cd $(EXPACKDIR);$(MAKE) -f Makefile.mingw expack.exe)

$(UCC):
	+(cd $(UCCDIR);$(MAKE) -f Makefile.mingw ucc.exe)


static/usecode: $(UCC) $(USECODE_OBJECTS)
	$(UCC) -I $(srcdir)/src/usecode -o $(srcdir)/static/usecode $(srcdir)/src/usecode/usecode.uc

static/fonts.vga: $(EXPACK) $(FONTS_VGA_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/fonts.in

static/gumps.vga: $(EXPACK) $(GUMPS_VGA_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/gumps.in

static/mainshp.flx: $(EXPACK) $(MAINSHP_FLX_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/mainshp.in

static/palettes.flx: $(EXPACK) $(PALETTES_FLX_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/palettes.in

static/paperdol.vga: $(EXPACK) $(PAPERDOL_VGA_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/paperdol.in

static/shapes.vga: $(EXPACK) $(SHAPES_VGA_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/shapes.in

static/sprites.vga: $(EXPACK) $(SPRITES_VGA_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/graphics/sprites.in

static/intro.flx: $(EXPACK) $(INTRO_FLX_OBJECTS)
	$(EXPACK) -i $(srcdir)/src/playscene/intro.in

clean:
	rm -f $(CLEANFILES)

